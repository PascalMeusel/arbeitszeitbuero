{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arbeitszeitbüro",
  "version": "0.1.0",
  "identifier": "de.local.arbeitszeitbuero",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173/simple",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arbeitszeitbüro",
        "width": 460,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
