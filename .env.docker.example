# Copy this file to .env.docker before running docker compose.

# Public DNS name that points to the Docker host.
# Caddy will request and renew HTTPS certificates automatically when ports 80 and 443 are reachable.
APP_HOST=time.example.com
APP_BASE_URL=https://time.example.com

# Required for the first Docker start with an empty database.
# Use a unique temporary password; the admin must change it on first login.
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Optional SMTP fallback. Admins can also configure SMTP inside Einstellungen -> Mailserver.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
