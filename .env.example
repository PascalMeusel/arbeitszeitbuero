PORT=4177
TIME_TRACKER_DATA=server/data/time-tracker.sqlite
TIME_TRACKER_BACKUP_DIR=server/backups
APP_BASE_URL=http://localhost:4177

# Required only for the first production start with an empty database.
# The first admin is forced to change this password on first login.
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Public Ed25519 key used to verify paid and free-grant license keys.
# Generate once with: npm run license:keypair -- --out-dir .license
# Keep license-private.pem secret and only deploy the public key.
LICENSE_PUBLIC_KEY=

# Optional SMTP fallback. Admins can also configure SMTP in Einstellungen -> Mailserver.
# If omitted there too, emails are stored in the SQLite outbox and logged.
# Example: SMTP_FROM="Arbeitszeitbüro <time@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
